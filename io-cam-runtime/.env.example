# Kopyalayın: cp .env.example .env
# pydantic-settings IO_CAM_ prefix ile okur.

IO_CAM_MOCK_HARDWARE=0
IO_CAM_SERIAL_PORT=/dev/ttyUSB0
IO_CAM_SERIAL_BAUD=115200
# IO_CAM_VACUUM_SENSOR_PIN=13
IO_CAM_CAMERA_INDEX=0
IO_CAM_CORS_ORIGINS=http://localhost:9002,http://127.0.0.1:9002

